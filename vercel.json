{
  "name": "aliss-labs",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "corepack enable pnpm && pnpm install",
  "framework": "vite",
  "outputDirectory": "dist/public",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}